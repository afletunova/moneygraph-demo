DATABASE_URL=postgresql://postgres:postgres@db:5432/aigraph
EDGAR_USER_AGENT=Your Name your@email.com

# Scheduler: EDGAR + RSS auto-run on these cadences; websearch stays
# manual-trigger-only (real $ per call, see POST /pipeline/websearch).
# PIPELINE_CRON: standard 5-field cron, UTC. Default weekly Monday 9am matches
# settings.snapshot_frequency_days=7 — EDGAR's own submissions-cache freshness
# window, so running more often just re-reads the same cached filing list.
PIPELINE_CRON=0 9 * * 1
# RSS has no such cache ceiling (each poll hits the live feed) — plain interval.
RSS_INTERVAL_HOURS=6

# OpenAI extraction backend
OPENAI_API_KEY=sk-...
EXTRACTION_MODE=realtime        # realtime | batch — realtime default keeps fresh clones debuggable
OPENAI_PRIMARY_MODEL=gpt-4o-mini
OPENAI_ESCALATION_MODEL=gpt-4o

# Websearch cost cap: skip nodes web-searched within this many days on refresh
# runs (keeps repeat runs under $1). 0 forces a full re-search of every node.
WEBSEARCH_STALE_DAYS=14

# Websearch hang guard: bound each OpenAI call and cap per-node wall-clock so one
# unresponsive node can't wedge the whole run.
WEBSEARCH_OPENAI_TIMEOUT_S=30
WEBSEARCH_OPENAI_MAX_RETRIES=1
WEBSEARCH_NODE_TIMEOUT_S=90

# Websearch discovery backend: Brave Search API — replaces
# the $0.025/call OpenAI web_search tool. Free tier (~2000 queries/month as of
# writing); get a key at https://api.search.brave.com/app/keys (sign up for the
# free "Base" plan under "Data for Search"). Required for search_node() to
# return any results — if unset, websearch logs a warning and skips discovery
# for that node (fails gracefully, does not crash the run).
BRAVE_SEARCH_API_KEY=

# Production override: set EXTRACTION_MODE=batch in your prod .env for 50% cost reduction
# (24h SLA; harvest via POST /pipeline/harvest or the scheduler)

# RSS ingest
# Business Wire feeds are per-selection tokenised URLs — generate yours at
# https://www.businesswire.com/portal/site/home/news/ and paste the full URL here.
# If unset, the Business Wire feed is skipped (the other feeds are hardcoded public URLs).
# BUSINESSWIRE_RSS_URL=https://feed.businesswire.com/rss/home/?rss=...
